CHAT_PRESENCE_TTL_SECONDS=86400

USE_GCS_MEDIA=False
GS_BUCKET_NAME=your-studyspace-media-bucket
GS_PROJECT_ID=your-google-cloud-project-id
GS_LOCATION=media
GS_QUERYSTRING_AUTH=True
GS_IAM_SIGN_BLOB=False
GS_SA_EMAIL=



DB_NAME=studyspace_db
DB_USER=studyspace_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5433

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

SENDGRID_API_KEY=your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=no-reply@study-space.org.uk
STUDYSPACE_ADMIN_EMAIL=admin@studyspace.com
USE_SENDGRID_EMAIL=False

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id-here
MICROSOFT_CLIENT_ID=your-microsoft-client-id-here

